[Unit]
Description=FastAPI app with Uvicorn
After=network.target

[Service]
User=admin
Group=admin
WorkingDirectory=/home/lior/fastapi-app
ExecStart=/home/lior/fastapi-app/venv/bin/uvicorn main:app --host 0.0.0.0 --por<span style="background-color:#FFFFFF"><font color="#300A24">&gt;</font></span>
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
