{
  "info": {
    "name": "ScenarioBot API",
    "description": "Step 1: Run 'Login' → token is saved automatically.\nStep 2: Run any other request — token is injected via {{access_token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://vid.michal-solutions.com/api",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string",
      "description": "Filled automatically after Login"
    },
    {
      "key": "phone_id",
      "value": "",
      "type": "string",
      "description": "Saved automatically after Provision"
    },
    {
      "key": "contact_id",
      "value": "",
      "type": "string",
      "description": "Saved automatically after creating contact"
    },
    {
      "key": "ping_sender_id",
      "value": "",
      "type": "string",
      "description": "Saved automatically after PING step 1"
    },
    {
      "key": "reply_message_id",
      "value": "",
      "type": "string",
      "description": "Saved automatically after polling replies"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login (get token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('access_token', json.access_token);",
                  "    console.log('✅ Token saved:', json.access_token.substring(0, 30) + '...');",
                  "} else {",
                  "    console.error('❌ No token in response:', JSON.stringify(json));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"your@email.com\",\n  \"password\": \"yourpassword\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get current user (me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "📱 Phones",
      "item": [
        {
          "name": "List my phones",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/phones/",
              "host": ["{{base_url}}"],
              "path": ["phones", ""]
            }
          }
        },
        {
          "name": "Provision phone",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.phone_id) {",
                  "    pm.collectionVariables.set('phone_id', json.phone_id);",
                  "    console.log('✅ Phone ID saved:', json.phone_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"972504476645\",\n  \"nickname\": \"Test Phone\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/phones/provision",
              "host": ["{{base_url}}"],
              "path": ["phones", "provision"]
            }
          }
        }
      ]
    },
    {
      "name": "👤 Contacts",
      "item": [
        {
          "name": "List contacts",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/contacts?phone_id={{phone_id}}",
              "host": ["{{base_url}}"],
              "path": ["contacts"],
              "query": [{ "key": "phone_id", "value": "{{phone_id}}" }]
            }
          }
        },
        {
          "name": "🔔 PING Flow",
          "item": [
            {
              "name": "Step 1: Send PING",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json();",
                      "if (json.success) {",
                      "    pm.collectionVariables.set('contact_id', json.contact_id);",
                      "    pm.collectionVariables.set('ping_sender_id', json.ping_sender_id);",
                      "    console.log('✅ PING sent!');",
                      "    console.log('Contact ID:', json.contact_id);",
                      "    console.log('Ping ID:', json.ping_sender_id);",
                      "    console.log('');",
                      "    console.log('📊 Next: Poll Step 2 for replies');",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{access_token}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phone_id\": \"{{phone_id}}\",\n  \"target_number\": \"972504476645\",\n  \"name\": \"דני מבדיקה\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/contacts/create-from-ping",
                  "host": ["{{base_url}}"],
                  "path": ["contacts", "create-from-ping"]
                }
              }
            },
            {
              "name": "Step 2: Poll for replies",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json();",
                      "const convs = json.conversations || [];",
                      "console.log('Found', convs.length, 'conversations');",
                      "if (convs.length > 0 && convs[0].replies?.length > 0) {",
                      "    pm.collectionVariables.set('reply_message_id', convs[0].replies[0].id);",
                      "    console.log('✅ Reply found! message_id saved');",
                      "    console.log('📊 Next: Run Step 3 to link LID');",
                      "} else {",
                      "    console.log('⏳ No replies yet - try again');",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{access_token}}" }
                ],
                "url": {
                  "raw": "{{base_url}}/contacts/outgoing-with-replies/{{phone_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["contacts", "outgoing-with-replies", "{{phone_id}}"]
                }
              }
            },
            {
              "name": "Step 3: Link LID",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json();",
                      "if (json.success) {",
                      "    console.log('✅ Contact linked!');",
                      "    console.log('LID:', json.contact.lid?.substring(0, 40));",
                      "    console.log('🎉 PING Flow complete!');",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{access_token}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"contact_id\": \"{{contact_id}}\",\n  \"message_id\": \"{{reply_message_id}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/contacts/select-response",
                  "host": ["{{base_url}}"],
                  "path": ["contacts", "select-response"]
                }
              }
            }
          ]
        }
      ]
    }
  ]
}